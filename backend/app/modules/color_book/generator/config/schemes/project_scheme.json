{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Coloring Book Project Schema",
    "description": "Defines the data structure for a coloring book project, including metadata, prompts, and multi-language publishing data.",
    "type": "object",
    "definitions": {
        "languageVersion": {
            "type": "object",
            "description": "Language-specific version of publishing data.",
            "properties": {
                "uploaderData": {
                    "type": "object",
                    "description": "Platform-specific upload data, translated into the target language.",
                    "properties": {
                        "Cover": {
                            "type": "string",
                            "description": "Path to language-specific cover PDF. To be filled manually."
                        },
                        "Manuscript": {
                            "type": "string",
                            "description": "Path to language-specific manuscript PDF. To be filled manually."
                        },
                        "Language": {
                            "type": "string",
                            "description": "Full language name for the uploader."
                        },
                        "Title": {
                            "type": "string",
                            "description": "Translated title."
                        },
                        "Subtitle": {
                            "type": "string",
                            "description": "Translated subtitle."
                        },
                        "Series": {
                            "type": "string"
                        },
                        "Author prefix": {
                            "type": "string"
                        },
                        "Author first name": {
                            "type": "string"
                        },
                        "Author last name": {
                            "type": "string"
                        },
                        "Contributor role": {
                            "type": "string"
                        },
                        "Contributor prefix": {
                            "type": "string"
                        },
                        "Contributor first name": {
                            "type": "string"
                        },
                        "Contributor last name": {
                            "type": "string"
                        },
                        "Description": {
                            "type": "string",
                            "description": "Translated book description."
                        },
                        "Public Domain": {
                            "type": "string"
                        },
                        "Minimum age": {
                            "type": "string"
                        },
                        "Maximum age": {
                            "type": "string"
                        },
                        "Primary Marketplace": {
                            "type": "string"
                        },
                        "Category 1": {
                            "type": "string"
                        },
                        "Category 2": {
                            "type": "string"
                        },
                        "Category 3": {
                            "type": "string"
                        },
                        "Keywords 1": {
                            "type": "string",
                            "description": "Translated keyword 1."
                        },
                        "Keywords 2": {
                            "type": "string",
                            "description": "Translated keyword 2."
                        },
                        "Keywords 3": {
                            "type": "string",
                            "description": "Translated keyword 3."
                        },
                        "Keywords 4": {
                            "type": "string",
                            "description": "Translated keyword 4."
                        },
                        "Keywords 5": {
                            "type": "string"
                        },
                        "Keywords 6": {
                            "type": "string"
                        },
                        "Keywords 7": {
                            "type": "string"
                        },
                        "Low-Content Book": {
                            "type": "string"
                        },
                        "Large print": {
                            "type": "string"
                        },
                        "ISBN": {
                            "type": "string"
                        },
                        "Imprint": {
                            "type": "string"
                        },
                        "Interior & paper type": {
                            "type": "string"
                        },
                        "Width (in)": {
                            "type": "string"
                        },
                        "Height (in)": {
                            "type": "string"
                        },
                        "Bleed Settings": {
                            "type": "string"
                        },
                        "Paperback cover finish": {
                            "type": "string"
                        },
                        "Cover include barcode": {
                            "type": "string"
                        },
                        "AI-Generated": {
                            "type": "string"
                        },
                        "AI-Texts": {
                            "type": "string"
                        },
                        "AI-Texts-Tool": {
                            "type": "string"
                        },
                        "AI-Images": {
                            "type": "string"
                        },
                        "AI-Images-Tools": {
                            "type": "string"
                        },
                        "AI-Translations": {
                            "type": "string"
                        },
                        "AI-Translations-Tool": {
                            "type": "string"
                        },
                        "Base all prices on Primary Marketplace price": {
                            "type": "string"
                        },
                        "Expanded Distribution": {
                            "type": "string"
                        },
                        "Amazon.com": {
                            "type": "string"
                        },
                        "Amazon.co.uk": {
                            "type": "string"
                        },
                        "Amazon.de": {
                            "type": "string"
                        },
                        "Amazon.fr": {
                            "type": "string"
                        },
                        "Amazon.es": {
                            "type": "string"
                        },
                        "Amazon.it": {
                            "type": "string"
                        },
                        "Amazon.ca": {
                            "type": "string"
                        },
                        "Amazon.com.au": {
                            "type": "string"
                        },
                        "Amazon.nl": {
                            "type": "string"
                        },
                        "Amazon.pl": {
                            "type": "string"
                        },
                        "Amazon.se": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "Language",
                        "Title",
                        "Subtitle",
                        "Series",
                        "Author prefix",
                        "Author first name",
                        "Author last name",
                        "Contributor role",
                        "Contributor prefix",
                        "Contributor first name",
                        "Contributor last name",
                        "Description",
                        "Public Domain",
                        "Minimum age",
                        "Maximum age",
                        "Primary Marketplace",
                        "Category 1",
                        "Category 2",
                        "Category 3",
                        "Keywords 1",
                        "Keywords 2",
                        "Keywords 3",
                        "Keywords 4",
                        "Keywords 5",
                        "Keywords 6",
                        "Keywords 7",
                        "Low-Content Book",
                        "Large print",
                        "ISBN",
                        "Imprint",
                        "Interior & paper type",
                        "Width (in)",
                        "Height (in)",
                        "Bleed Settings",
                        "Paperback cover finish",
                        "Cover include barcode",
                        "AI-Generated",
                        "AI-Texts",
                        "AI-Texts-Tool",
                        "AI-Images",
                        "AI-Images-Tools",
                        "AI-Translations",
                        "AI-Translations-Tool",
                        "Base all prices on Primary Marketplace price",
                        "Expanded Distribution",
                        "Amazon.com",
                        "Amazon.co.uk",
                        "Amazon.de",
                        "Amazon.fr",
                        "Amazon.es",
                        "Amazon.it",
                        "Amazon.ca",
                        "Amazon.com.au",
                        "Amazon.nl",
                        "Amazon.pl",
                        "Amazon.se"
                    ]
                }
            },
            "required": [
                "uploaderData"
            ]
        }
    },
    "properties": {
        "coloringBook": {
            "type": "object",
            "properties": {
                "mainProjectDetails": {
                    "type": "object",
                    "description": "Core, language-agnostic details of the coloring book project.",
                    "properties": {
                        "generationLanguage": {
                            "type": "string",
                            "description": "Language for all AI-facing text (e.g., prompts, briefs). Must be English for tool compatibility.",
                            "const": "English"
                        },
                        "contentSafetyGuidelines": {
                            "type": "string",
                            "description": "Safety rules for all generated content. Must be family-friendly and adhere to responsible AI practices.",
                            "const": "Strictly adhere to content safety policies. All content must be family-friendly. AVOID sensitive, harmful, or explicit themes. CRITICAL: DO NOT use direct terms for people (e.g., 'child', 'boy', 'girl'). INSTEAD, use descriptive alternatives like 'young explorer', 'tiny adventurer', 'youthful figure'."
                        },
                        "title": {
                            "type": "string",
                            "description": "The original title of the coloring book."
                        },
                        "author": {
                            "type": "string",
                            "description": "The author or creator of the coloring book."
                        },
                        "suggestedUniversalAuthorName": {
                            "type": "object",
                            "description": "Suggestion for a universal, fictional author name suitable for multiple languages.",
                            "properties": {
                                "firstName": {
                                    "type": "string",
                                    "description": "Suggested universal first name.",
                                    "examples": [
                                        "Alex",
                                        "Jordan",
                                        "Kai"
                                    ]
                                },
                                "lastName": {
                                    "type": "string",
                                    "description": "Suggested universal last name.",
                                    "examples": [
                                        "Stone",
                                        "Rivers",
                                        "Green"
                                    ]
                                },
                                "fullDisplayName": {
                                    "type": "string",
                                    "description": "Full suggested author name for display."
                                }
                            },
                            "required": [
                                "firstName",
                                "lastName",
                                "fullDisplayName"
                            ]
                        },
                        "ageRange": {
                            "type": "string",
                            "description": "Target audience or age range (e.g., '3-8 years', 'adults', 'all ages').",
                            "examples": [
                                "3-8 years",
                                "youths (12-18)",
                                "adults",
                                "seniors",
                                "all ages"
                            ]
                        },
                        "mainTheme": {
                            "type": "string",
                            "description": "The main subject of the book, including the target audience (e.g., 'Forest Animals for Kids').",
                            "examples": [
                                "Enchanted Forests for Young Adventurers",
                                "Space Explorers for All Ages"
                            ]
                        },
                        "creativeBrief": {
                            "type": "string",
                            "description": "A short creative directive for the AI to guide the overall artistic vision. Must be in English."
                        },
                        "artStyleGuidance": {
                            "type": "array",
                            "description": "Keywords defining the primary art style for the AI. Must be in English.",
                            "items": {
                                "type": "string",
                                "examples": [
                                    "cartoon",
                                    "abstract",
                                    "manga",
                                    "vintage",
                                    "minimalist",
                                    "line art",
                                    "geometric",
                                    "whimsical"
                                ]
                            },
                            "uniqueItems": true
                        },
                        "aspectRatio": {
                            "type": "string",
                            "description": "Aspect ratio for all graphics is fixed at 3:4 to match A4 paper.",
                            "const": "3:4"
                        },
                        "coloringPageGuidelines": {
                            "type": "string",
                            "description": "Strict rules for generating all coloring page images.",
                            "const": "CREATE: black and white line art. OUTLINES: black, on a pure white background. NO: solid fills, shading, grayscale, color. PAGE FILL: Design must cover >75% of the canvas. SPACING: Distribute elements to avoid any single empty white area that exceeds 10% of the page. DETAIL: Use simple, clear lines for faces and limbs; avoid complex details to prevent distortion."
                        },
                        "coverDetails": {
                            "type": "object",
                            "description": "Universal design details for the book cover.",
                            "properties": {
                                "graphicStyle": {
                                    "type": "string",
                                    "description": "Artistic style for the cover image (fully colored). Must be in English.",
                                    "examples": [
                                        "vibrant cartoon",
                                        "detailed illustration",
                                        "whimsical watercolor"
                                    ]
                                },
                                "sceneDescription": {
                                    "type": "string",
                                    "description": "Detailed description for the cover graphic. Must be in English."
                                }
                            },
                            "required": [
                                "graphicStyle",
                                "sceneDescription"
                            ]
                        },
                        "pageIdeas": {
                            "type": "array",
                            "description": "A list of 40 page ideas, each linking to a prompt in the 'pagePromptLibrary'.",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "pageNumber": {
                                        "type": "integer",
                                        "description": "The page number."
                                    },
                                    "promptReferenceId": {
                                        "type": "string",
                                        "description": "Links to a `promptId` in the pagePromptLibrary."
                                    }
                                },
                                "required": [
                                    "pageNumber",
                                    "promptReferenceId"
                                ]
                            },
                            "minItems": 40,
                            "maxItems": 40
                        },
                        "numberOfPages": {
                            "type": "integer",
                            "description": "Total number of pages in the coloring book, fixed at 40.",
                            "const": 40
                        }
                    },
                    "required": [
                        "generationLanguage",
                        "contentSafetyGuidelines",
                        "title",
                        "author",
                        "suggestedUniversalAuthorName",
                        "ageRange",
                        "mainTheme",
                        "creativeBrief",
                        "artStyleGuidance",
                        "aspectRatio",
                        "coloringPageGuidelines",
                        "coverDetails",
                        "pageIdeas",
                        "numberOfPages"
                    ]
                },
                "pagePromptLibrary": {
                    "type": "array",
                    "description": "A library of detailed prompts for individual coloring pages, referenced by 'pageIdeas'.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "promptId": {
                                "type": "string",
                                "description": "Unique identifier for this page prompt.",
                                "examples": [
                                    "page_squirrel_01",
                                    "page_bear_forest_02"
                                ]
                            },
                            "sceneDescription": {
                                "type": "string",
                                "description": "**CRITICAL:** The detailed prompt for the image generator. Describe the scene, subjects, and composition. **The description should guide the AI to generate simpler illustrations with fewer distinct, larger colorable areas, aiming for approximately 200 sections per page.** Must follow all `coloringPageGuidelines`. Must be in English.",
                                "examples": [
                                    "A majestic griffin on a high tree branch under a full moon, misty forest background, twinkling stars. Pure black outlines on white.",
                                    "A cheerful young dwarf tending to glowing mushrooms in a magical cave with crystal formations. Pure black outlines on white."
                                ]
                            },
                            "graphicStyle": {
                                "type": "string",
                                "description": "Specific graphic style for this page. This style is fixed to ensure a consistent coloring book aesthetic: **pure black, thick, continuous outlines creating clearly defined, enclosed white areas for coloring, resembling a simple stained-glass window design. Emphasize fewer, larger sections over intricate detail.** No fills, no shading, no grayscale. This style overrides any general art style guidance for individual pages. Must be in English.",
                                "const": "pure black outlines, simple stained-glass style, white fillable areas, coloring book pages, all lines must be closed, aiming for around 200 colorable fields, 2D, no detail faces"
                            },
                            "emotionalTone": {
                                "type": "string",
                                "description": "Desired emotional tone for the page (e.g., 'peaceful', 'adventurous'). Must be in English.",
                                "examples": [
                                    "peaceful",
                                    "adventurous",
                                    "playful",
                                    "mysterious",
                                    "joyful",
                                    "serene"
                                ]
                            },
                            "complexityLevel": {
                                "type": "integer",
                                "description": "The level of detail in the line art on a scale from 1 to 100. Low values (e.g., 1-20) indicate simple designs with large, clear areas, suitable for young children. High values (e.g., 80-100) indicate very complex and intricate designs with many small details, suitable for adults (e.g., mandalas, detailed patterns).",
                                "minimum": 1,
                                "maximum": 100
                            }
                        },
                        "required": [
                            "promptId",
                            "sceneDescription",
                            "graphicStyle",
                            "emotionalTone",
                            "complexityLevel"
                        ]
                    },
                    "minItems": 40,
                    "uniqueItems": true
                },
                "languageVersions": {
                    "type": "object",
                    "description": "Contains language-specific versions of publishing data for each target language.",
                    "properties": {
                        "en": {
                            "$ref": "#/definitions/languageVersion"
                        },
                        "es": {
                            "$ref": "#/definitions/languageVersion"
                        },
                        "pt": {
                            "$ref": "#/definitions/languageVersion"
                        },
                        "pl": {
                            "$ref": "#/definitions/languageVersion"
                        },
                        "fr": {
                            "$ref": "#/definitions/languageVersion"
                        },
                        "de": {
                            "$ref": "#/definitions/languageVersion"
                        },
                        "it": {
                            "$ref": "#/definitions/languageVersion"
                        },
                        "nl": {
                            "$ref": "#/definitions/languageVersion"
                        },
                        "sv": {
                            "$ref": "#/definitions/languageVersion"
                        }
                    },
                    "required": [
                        "en",
                        "es",
                        "pt",
                        "pl",
                        "fr",
                        "de",
                        "it",
                        "nl",
                        "sv"
                    ]
                }
            },
            "required": [
                "mainProjectDetails",
                "pagePromptLibrary",
                "languageVersions"
            ]
        }
    },
    "required": [
        "coloringBook"
    ]
}